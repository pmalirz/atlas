# =============================================================================
# Atlas Server Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://atlas:atlas_dev_password@localhost:5432/app_atlas?schema=public"

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3001
NODE_ENV=development

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Auth Provider: native | clerk | logto | sso
AUTH_PROVIDER=native

# JWT Settings (used by native provider and for session tokens)
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Clerk Provider Settings (if AUTH_PROVIDER=clerk)
# -----------------------------------------------------------------------------
# CLERK_SECRET_KEY=sk_test_...
# CLERK_PUBLISHABLE_KEY=pk_test_...

# -----------------------------------------------------------------------------
# Logto Provider Settings (if AUTH_PROVIDER=logto)
# -----------------------------------------------------------------------------
# LOGTO_ENDPOINT=https://your-tenant.logto.app
# LOGTO_APP_ID=your-app-id
# LOGTO_APP_SECRET=your-app-secret

# -----------------------------------------------------------------------------
# SSO Provider Settings (if AUTH_PROVIDER=sso)
# -----------------------------------------------------------------------------
# SSO_TYPE=oidc
# SSO_ISSUER=https://login.microsoftonline.com/{tenant-id}/v2.0
# SSO_CLIENT_ID=your-client-id
# SSO_CLIENT_SECRET=your-client-secret
# SSO_DISCOVERY_URL=https://login.microsoftonline.com/{tenant-id}/v2.0/.well-known/openid-configuration


# -----------------------------------------------------------------------------
# Email Configuration
# -----------------------------------------------------------------------------
# Option 1: Mailpit (local development)
# Run `docker compose up` to start Mailpit
# View emails at http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM=noreply@atlas.local
APP_URL=http://localhost:8081
APP_NAME=Atlas

# Option 2: Resend SMTP (production/staging)
# See: https://resend.com/docs/send-with-smtp
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=resend
# SMTP_PASS=re_YOUR_API_KEY_HERE
# SMTP_FROM=atlas@your-verified-domain.com

# Option 3: Generic SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@example.com


# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Global rate limiting (all endpoints):
# THROTTLE_TTL: time window in milliseconds (default: 60000 = 1 minute)
# THROTTLE_LIMIT: max requests per window (default: 100)
# THROTTLE_TTL=60000
# THROTTLE_LIMIT=100

# Auth-specific rate limiting (login, register, password reset - stricter):
# THROTTLE_AUTH_TTL: time window in milliseconds (default: 60000 = 1 minute)
# THROTTLE_AUTH_LIMIT: max auth requests per window (default: 10)
# THROTTLE_AUTH_TTL=60000
# THROTTLE_AUTH_LIMIT=10

# For E2E tests, set both to 100000 to effectively disable rate limiting